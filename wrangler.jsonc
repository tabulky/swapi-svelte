{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "swapi-svelte",
  "compatibility_date": "2026-03-01",
  "compatibility_flags": ["nodejs_compat", "nodejs_als"],
  "main": ".svelte-kit/cloudflare/_worker.js",
  "assets": {
    "binding": "ASSETS",
    "directory": ".svelte-kit/cloudflare",
  },
  "workers_dev": true,
  "preview_urls": true,
  "observability": {
    "enabled": true,
  },
}
